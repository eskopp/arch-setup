# Normalize text files to LF in the repository
* text=auto eol=lf

# Shell scripts
*.sh text eol=lf

# Config and docs
*.md text eol=lf
*.txt text eol=lf
*.conf text eol=lf
*.service text eol=lf
*.timer text eol=lf
*.hook text eol=lf
*.rules text eol=lf
*.pacnew text eol=lf
*.example text eol=lf

# YAML / JSON
*.yml text eol=lf
*.yaml text eol=lf
*.json text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.webp binary
*.ico binary
*.zip binary
*.tar binary
*.gz binary
*.7z binary
*.ttf binary
*.otf binary

# GitHub Linguist
*.sh linguist-language=Shell
